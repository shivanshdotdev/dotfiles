[global]
    monitor = 0
    origin = top-right
    offset = 10x10
    width = 380
    height = 120
    padding = 15
    horizontal_padding = 15
    frame_width = 2
    frame_color = "#cba6f7"
    gap_size = 5
    font = CaskaydiaCove Nerd Font Mono 12
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    transparency = 15
    corner_radius = 8
    timeout = 3

[urgency_low]
    background = "#1e1e2e"
    foreground = "#a6adc8"
    timeout = 3
    script = /home/shivansh/.config/dunst/notify-sound.sh

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 5
    script = /home/shivansh/.config/dunst/notify-sound.sh


[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
    script = /home/shivansh/.config/dunst/notify-sound.sh
